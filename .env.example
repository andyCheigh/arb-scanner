# Telegram bot — recommended: a SEPARATE bot from ticket-edge so you can mute one
# without losing the other. Create via @BotFather → /newbot → token.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# The Odds API — free tier 500 req/month. Sign up at https://the-odds-api.com/
ODDS_API_KEY=
# Optional second key for round-robin (doubles your monthly budget to 1000)
ODDS_API_KEY_2=

# Tuning (all optional)
MIN_PROFIT_PCT=1.0          # alert threshold; raise to 2.0 to cut noise
BANKROLL_USD=1000           # stake-allocation reference amount per arb

# Comma-separated. Skip a sport by removing it from the list.
# Defaults: NFL, NBA, MLB, NHL, EPL soccer (UFC dropped — high event count, low arb yield)
SPORTS=americanfootball_nfl,basketball_nba,baseball_mlb,icehockey_nhl,soccer_epl

# Comma-separated bookmaker keys. Adding more books does NOT cost more
# requests (Odds API charges per event×market×region, not per book).
# Sharp / major US: draftkings, fanduel, betmgm, caesars, betrivers, espnbet, williamhill_us, pinnacle
# Soft / offshore (often the +EV leg of an arb): bovada, betus, mybookieag, lowvig, betonlineag, hardrockbet, fanatics, fliff
BOOKS=draftkings,fanduel,betmgm,caesars,betrivers,espnbet,williamhill_us,pinnacle,bovada,betus,mybookieag,lowvig,betonlineag,hardrockbet,fanatics,fliff

# Scan window in Pacific time. Default: 6 evenly-spaced scans 9am→11pm PT.
SCAN_WINDOW_START_HOUR=9
SCAN_WINDOW_END_HOUR=23
SCAN_COUNT=6
